        "@supabase/supabase-js": "^2.99.2",
        "@tanstack/react-query": "^5.90.21",
        "@vercel/blob": "^2.3.1",
        "bcryptjs": "^3.0.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "jsonwebtoken": "^9.0.3",
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.7",
        "lucide-react": "^0.577.0",
        "next": "16.1.6",
        "next-auth": "^5.0.0-beta.30",
        "next-themes": "^0.4.6",
        "radix-ui": "^1.4.3",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hook-form": "^7.71.2",
        "react-is": "^19.2.7",
        "recharts": "^3.8.0",
        "resend": "^6.9.3",
        "shadcn": "^4.0.2",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "uuid": "^14.0.1",
        "zod": "^4.3.6"
