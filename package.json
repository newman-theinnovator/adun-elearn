        "jsdom": "^29.1.1",
        "lint-staged": "^17.0.8",
        "prettier": "^3.9.4",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "prisma": "^5.22.0",
        "tailwindcss": "^4",
        "ts-node": "^10.9.2",
        "typescript": "^5",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.9"
